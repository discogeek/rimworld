<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <TraderKindDef>
    <defName>GR_Alliance_Caravan</defName>
    <label>alliance supply caravan</label>
    <stockGenerators>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>750~1200</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>ComponentIndustrial</thingDef>
        <countRange>6~20</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Steel</thingDef>
        <countRange>250~400</countRange>
      </li>
      <li Class="StockGenerator_MarketValue">
        <tradeTag>GR_ModWeapon</tradeTag>
        <countRange>2~4</countRange>
      </li>
      <li Class="StockGenerator_MarketValue">
        <tradeTag>GR_AllianceApparel</tradeTag>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_Animals">
        <tradeTagsSell>
          <li>AnimalFarm</li>
        </tradeTagsSell>
        <kindCountRange>1~2</kindCountRange>
        <totalPriceRange>200~600</totalPriceRange>
      </li>
    </stockGenerators>
  </TraderKindDef>

  <FactionDef ParentName="FactionBase">
    <defName>GR_GalacticAuthority</defName>
    <label>galactic authority</label>
    <description>A disciplined occupation force enforcing order across the rim. Their troopers arrive in armored columns and expect compliance.</description>
    <pawnSingular>authority trooper</pawnSingular>
    <pawnsPlural>authority troopers</pawnsPlural>
    <categoryTag>GR_GalacticAuthority</categoryTag>
    <listOrderPriority>280</listOrderPriority>
    <settlementGenerationWeight>1</settlementGenerationWeight>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <maxCountAtGameStart>1</maxCountAtGameStart>
    <canMakeRandomly>true</canMakeRandomly>
    <canSiege>true</canSiege>
    <canStageAttacks>true</canStageAttacks>
    <leaderTitle>sector marshal</leaderTitle>
    <factionNameMaker>GR_NamerFactionAuthority</factionNameMaker>
    <settlementNameMaker>GR_NamerFactionAuthority</settlementNameMaker>
    <techLevel>Industrial</techLevel>
    <backstoryFilters>
      <li>
        <categories>
          <li>Soldier</li>
        </categories>
      </li>
    </backstoryFilters>
    <allowedCultures>
      <li>Astropolitan</li>
    </allowedCultures>
    <fixedLeaderKinds>
      <li>GR_AuthorityElite</li>
    </fixedLeaderKinds>
    <autoFlee>false</autoFlee>
    <hostileToFactionlessHumanlikes>true</hostileToFactionlessHumanlikes>
    <naturalEnemy>true</naturalEnemy>
    <colorSpectrum>
      <li>(0.15, 0.15, 0.18)</li>
      <li>(0.35, 0.35, 0.40)</li>
    </colorSpectrum>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 0.12)</li>
        <li>(1000, 0.35)</li>
        <li>(5000, 0.55)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(0, 120)</li>
        <li>(10000, 250)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <commonality>100</commonality>
        <options>
          <GR_AuthorityTrooper>8</GR_AuthorityTrooper>
          <GR_AuthorityElite>2</GR_AuthorityElite>
        </options>
      </li>
      <li>
        <kindDef>Settlement</kindDef>
        <options>
          <GR_AuthorityTrooper>6</GR_AuthorityTrooper>
          <GR_AuthorityElite>3</GR_AuthorityElite>
        </options>
      </li>
    </pawnGroupMakers>
  </FactionDef>

  <FactionDef ParentName="FactionBase">
    <defName>GR_FreeSystemsAlliance</defName>
    <label>free systems alliance</label>
    <description>Decentralized rebels and smugglers resisting authority rule. They trade quietly and strike when they can.</description>
    <pawnSingular>alliance fighter</pawnSingular>
    <pawnsPlural>alliance fighters</pawnsPlural>
    <categoryTag>GR_FreeSystemsAlliance</categoryTag>
    <listOrderPriority>290</listOrderPriority>
    <settlementGenerationWeight>1</settlementGenerationWeight>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <maxCountAtGameStart>1</maxCountAtGameStart>
    <canMakeRandomly>true</canMakeRandomly>
    <canSiege>false</canSiege>
    <canStageAttacks>true</canStageAttacks>
    <leaderTitle>cell commander</leaderTitle>
    <factionNameMaker>GR_NamerFactionAlliance</factionNameMaker>
    <settlementNameMaker>GR_NamerFactionAlliance</settlementNameMaker>
    <techLevel>Industrial</techLevel>
    <backstoryFilters>
      <li>
        <categories>
          <li>Offworld</li>
        </categories>
      </li>
    </backstoryFilters>
    <allowedCultures>
      <li>Astropolitan</li>
    </allowedCultures>
    <fixedLeaderKinds>
      <li>GR_AllianceSoldier</li>
    </fixedLeaderKinds>
    <autoFlee>false</autoFlee>
    <hostileToFactionlessHumanlikes>false</hostileToFactionlessHumanlikes>
    <naturalEnemy>false</naturalEnemy>
    <colorSpectrum>
      <li>(0.55, 0.15, 0.10)</li>
      <li>(0.75, 0.35, 0.20)</li>
    </colorSpectrum>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 0.08)</li>
        <li>(1000, 0.20)</li>
        <li>(5000, 0.35)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(0, 100)</li>
        <li>(10000, 200)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <caravanTraderKinds>
      <li>GR_Alliance_Caravan</li>
    </caravanTraderKinds>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <commonality>100</commonality>
        <options>
          <GR_AllianceSoldier>10</GR_AllianceSoldier>
        </options>
      </li>
      <li>
        <kindDef>Trader</kindDef>
        <traders>
          <GR_AllianceTrader>1</GR_AllianceTrader>
        </traders>
        <guards>
          <GR_AllianceSoldier>4</GR_AllianceSoldier>
        </guards>
      </li>
      <li>
        <kindDef>Settlement</kindDef>
        <options>
          <GR_AllianceSoldier>8</GR_AllianceSoldier>
        </options>
      </li>
    </pawnGroupMakers>
  </FactionDef>
</Defs>
