  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>GR_HoldoutBlaster</defName>
    <label>holdout blaster</label>
    <description>A compact sidearm that fires superheated plasma bolts. Reliable at close range.</description>
    <tradeTags>
      <li>GR_ModWeapon</li>
      <li>WeaponRanged</li>
    </tradeTags>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/GR_HoldoutBlaster</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <weaponTags>
      <li>GR_HoldoutBlaster</li>
      <li>SimpleGun</li>
    </weaponTags>
    <statBases>
      <WorkToMake>6000</WorkToMake>
      <Mass>1.2</Mass>
      <AccuracyTouch>0.80</AccuracyTouch>
      <AccuracyShort>0.75</AccuracyShort>
      <AccuracyMedium>0.55</AccuracyMedium>
      <AccuracyLong>0.35</AccuracyLong>
      <RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
    </statBases>
    <recipeMaker>
      <researchPrerequisite>GR_BasicGalacticArms</researchPrerequisite>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
    </recipeMaker>
    <costList>
      <Steel>40</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>GR_Bullet_BlasterBolt</defaultProjectile>
        <warmupTime>0.35</warmupTime>
        <range>22.9</range>
        <soundCast>Shot_Revolver</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

