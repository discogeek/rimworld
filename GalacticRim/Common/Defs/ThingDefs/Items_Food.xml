    <label>sunbulb tuber</label>
    <description>A dense, starchy tuber from sunbulb plants. A staple on arid rim worlds.</description>
    <graphicData>
      <texPath>Things/Item/Resource/PlantFoodRaw/GR_Raw_Sunbulb</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>1.1</MarketValue>
      <Mass>0.015</Mass>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <ingestible>
      <foodType>Vegetable</foodType>
      <preferability>RawBad</preferability>
      <tasteThought/>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>RawVegetable_Eat</ingestSound>
