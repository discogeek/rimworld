<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="LightMechanoid" MayRequire="Ludeon.RimWorld.Biotech">
    <defName>GR_UtilityDroid</defName>
    <label>utility droid</label>
    <description>A light service droid built for hauling, cleaning, and basic colony upkeep. Its chassis is styled after common rim-world astromech patterns.</description>
    <statBases>
      <MoveSpeed>3.2</MoveSpeed>
      <MarketValue>900</MarketValue>
    </statBases>
    <race>
      <mechEnabledWorkTypes>
        <li>Hauling</li>
        <li>Cleaning</li>
        <li>Construction</li>
        <li>Crafting</li>
      </mechEnabledWorkTypes>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Lifter_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Lifter_Death</soundDeath>
          <soundCall>Pawn_Mech_Lifter_Call</soundCall>
        </li>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>100</minAge>
          <soundWounded>Pawn_Mech_Lifter_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Lifter_Death</soundDeath>
          <soundCall>Pawn_Mech_Lifter_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="NonCombatLightMechanoidKind" MayRequire="Ludeon.RimWorld.Biotech">
    <defName>GR_UtilityDroid</defName>
    <label>utility droid</label>
    <race>GR_UtilityDroid</race>
    <defaultFactionDef>GR_FreeSystemsAlliance</defaultFactionDef>
    <combatPower>25</combatPower>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/GR_UtilityDroid/GR_UtilityDroid</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Liftman</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.1</drawSize>
        </bodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/GR_UtilityDroid/GR_UtilityDroid</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Liftman</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.1</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>
</Defs>
