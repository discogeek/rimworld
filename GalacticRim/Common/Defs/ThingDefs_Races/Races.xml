    <techHediffsMoney>0~0</techHediffsMoney>
    <techHediffsTags>
      <li>Poor</li>
    </techHediffsTags>
    <gearHealthRange>1~1</gearHealthRange>
    <minGenerationAge>0</minGenerationAge>
    <maxGenerationAge>100</maxGenerationAge>
    <chronologicalAgeRange>1~200</chronologicalAgeRange>
    <nameMaker>GR_NamerPersonAuthority</nameMaker>
    <fixedGender>Male</fixedGender>
    <skills>
